---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { slug, formatDate } from '../lib/utils';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Base title="Jesus Garcia">
  <section class="page-section">
    <h1 class="page-section-title page-section-title--index">Writing</h1>
    <p class="index-intro">Talks, ideas, and the things I learn along the way.</p>

    <div class="post-list">
      {posts.map((post) => (
        <a href={`/blog/${slug(post.id)}/`} class="post-entry">
          <h2 class="post-entry-title">{post.data.title}</h2>
          <time class="post-entry-date" datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
        </a>
      ))}
    </div>
  </section>
</Base>
