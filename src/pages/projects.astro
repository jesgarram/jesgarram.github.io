---
import Base from '../layouts/Base.astro';

const projects = [
  {
    name: 'Arete',
    role: 'Creator',
    url: 'https://github.com/jesgarram/arete',
    postUrl: '/blog/the-annoying-senior-engineer-i-built/',
    description: 'A brainstorming agent that challenges your thinking through five structured phases — Ground, Explore, Decide, Stress, Ship — before you commit to decisions. The annoying senior engineer, as a plugin.',
  },
  {
    name: 'Verbatim',
    role: 'Creator',
    url: 'https://github.com/jesgarram/verbatim',
    postUrl: '/blog/the-blog-post-that-wrote-itself/',
    description: 'A transcript-to-blog-post pipeline. Structure, polish, and refine your talks into written posts that sound like you wrote them yourself. Your voice in, your voice out.',
  },
];
---

<Base title="Projects — Jesus Garcia" description="Open-source projects by Jesus Garcia.">
  <section class="page-section">
    <h1 class="page-section-title">Projects</h1>

    <div class="projects-list">
      {projects.map((project) => (
        <div class="project-entry">
          <h2 class="project-entry-name">{project.name}</h2>
          <span class="project-entry-role">{project.role}</span>
          <p class="project-entry-description">{project.description}</p>
          <div class="project-entry-actions">
            <a href={project.url} class="project-btn project-btn--primary" target="_blank" rel="noopener">Open</a>
            {project.postUrl && (
              <a href={project.postUrl} class="project-btn project-btn--secondary">Read</a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
